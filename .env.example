APP_NAME=MPKDocumentsAPI
ENVIRONMENT=dev

JWT_SECRET=change-me
JWT_ISSUER=mpk-documents
JWT_AUDIENCE=mpk-documents-clients
JWT_EXPIRES_MINUTES=10080

# Дополнительные id администраторов через запятую (помимо Users.IsAdmin=1 в БД). Пример: 1,5
MPK_ADMIN_USER_IDS=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=MPKDocuments

# Россия +7: smsc (SMSC.ru) или smsru (SMS.RU). Код на почту: email (SMTP, например Яндекс).
# Twilio/Vonage — не для РФ.
SMS_PROVIDER=smsc

# --- Код подписания на email — SMS_PROVIDER=email — пароль приложения Яндекса (не от входа в почту).
# Поддерживаются имена как в Django или SMTP_*:
# EMAIL_HOST=smtp.yandex.ru
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_HOST_USER=noreply@yandex.ru
# EMAIL_HOST_PASSWORD=app-password
# DEFAULT_FROM_EMAIL=noreply@yandex.ru
# (альтернатива: SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASSWORD, SMTP_FROM, SMTP_USE_SSL)
# OTP_EMAIL_SUBJECT=Код подписания — МПК Документы
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Уведомления на почту о документе (очередь подписания, подписал/отклонил). Тот же SMTP; false — не отправлять.
DOCUMENT_NOTIFY_EMAIL_ENABLED=true

# --- SMS.RU https://sms.ru/ — SMS_PROVIDER=smsru
# SMSRU_API_ID=
# SMSRU_FROM=


# --- Vonage / Nexmo — https://dashboard.nexmo.com/ — SMS_PROVIDER=vonage
# VONAGE_API_KEY=
# VONAGE_API_SECRET=
# VONAGE_FROM=VonageMsgs

# --- Twilio — SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+12025550100

# --- SMSC.ru — OTP (https://smsc.ru/api/). Либо SMSC_API_KEY, либо SMSC_LOGIN + SMSC_PASSWORD.
SMSC_API_KEY=
SMSC_LOGIN=
SMSC_PASSWORD=
# Только зарегистрированное в кабинете имя; иначе ошибка 6 — лучше оставить пустым:

# Текст SMS (подстрока {code}); латиница по умолчанию реже даёт ошибку 6 у SMSC:
# SMSC_OTP_MESSAGE_TEMPLATE=Code: {code}
# Если шаблон на кириллице и шлюз отклоняет — попробуйте 1:
# SMSC_OTP_TRANSLIT=0

# Без SMS (разработка): OTP в логах uvicorn
OTP_DEV_MODE=false
# Вместе с OTP_DEV_MODE=true — вернуть код в JSON ответа (только локально!)
OTP_DEV_RETURN_CODE=false

